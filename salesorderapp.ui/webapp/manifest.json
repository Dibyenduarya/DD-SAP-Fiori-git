{
  "_version": "1.42.0",
  "sap.app": {
    "id": "salesorderapp.ui",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.27.0",
      "toolsId": "5f189e3c-d3ef-42cc-b322-9dd69b8858b4"
    },
    "dataSources": {
      "RFM_MANAGE_SALES_ORDERS_ANNO_MDL": {
        "uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='RFM_MANAGE_SALES_ORDERS_ANNO_MDL',Version='0001')/$value/",
        "type": "ODataAnnotation",
        "settings": {
          "localUri": "localService/mainService/RFM_MANAGE_SALES_ORDERS_ANNO_MDL.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata/sap/RFM_MANAGE_SALES_ORDERS_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [
            "RFM_MANAGE_SALES_ORDERS_ANNO_MDL"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "ZFIORI_DD_SEMOBJ-display": {
          "semanticObject": "ZFIORI_DD_SEMOBJ",
          "action": "display",
          "title": "{{ZFIORI_DD_SEMOBJ-display.flpTitle}}",
          "subTitle": "{{ZFIORI_DD_SEMOBJ-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        },
        "ZDD_SEMOBJ-display": {
          "semanticObject": "ZDD_SEMOBJ",
          "action": "display",
          "title": "{{ZDD_SEMOBJ-display.flpTitle}}",
          "subTitle": "{{ZDD_SEMOBJ-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.102.8",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "salesorderapp.ui.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      },
      "ProductModel": {
        "type": "sap.ui.model.json.JSONModel"
      },
      "SelectedProductModel": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "salesorderapp.ui.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteOrderList",
          "pattern": ":?query:",
          "target": [
            "TargetOrderList"
          ]
        },
        {
          "name": "RouteProductDisplay",
          "pattern": "DisplayProduct/{ProductId}",
          "target": [
            "TargetDisplayProduct"
          ]
        }
      ],
      "targets": {
        "TargetOrderList": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "OrderList",
          "viewName": "OrderList"
        },
        "TargetDisplayProduct": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "DisplayProduct",
          "viewName": "DisplayProduct"
        }
      }
    },
    "rootView": {
      "viewName": "salesorderapp.ui.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  }
}
